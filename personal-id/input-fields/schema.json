{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://europa.eu/eudi/pid-claims.schema.json",
    "title": "EUDI Personal Identification Data (PID) Claims",
    "type": "object",
    "properties": {
        "vct": {
            "title": "",
            "description": "Credential type identifier",
            "type": "string",
            "const": "urn:eudi:pid:1"
        },
        "familyName": {
            "title": "Family Name",
            "description": "",
            "type": "string"
        },
        "givenName": {
            "title": "",
            "description": "",
            "type": "string"
        },
        "birthdate": {
            "title": "",
            "description": "",
            "type": "string",
            "format": "date"
        },
        "placeOfBirth": {
            "title": "",
            "description": "",
            "$ref": "#/$defs/place_of_birth"
        },
        "nationalities": {
            "title": "",
            "description": "",
            "type": "array",
            "items": {
                "$ref": "#/$defs/country_code"
            }
        },
        "address": {
            "title": "",
            "description": "",
            "$ref": "#/$defs/address"
        },
        "birthFamilyName": {
            "title": "",
            "description": "",
            "type": "string"
        },
        "birthGivenName": {
            "title": "",
            "description": "",
            "type": "string"
        },
        "email": {
            "title": "",
            "description": "",
            "type": "string",
            "format": "email"
        },
        "phoneNumber": {
            "title": "",
            "description": "",
            "type": "string"
        },
        "picture": {
            "title": "",
            "description": "JPEG data URL",
            "type": "string",
            "pattern": "^data:image\\/jpeg;base64,"
        },
        "dateOfExpiry": {
            "title": "",
            "description": "",
            "type": "string",
            "format": "date"
        },
        "dateOfIssuance": {
            "title": "",
            "description": "",
            "type": "string",
            "format": "date"
        },
        "personalAdministrativeNumber": {
            "title": "",
            "description": "",
            "type": "string"
        },
        "sex": {
            "title": "",
            "description": "0 unknown, 1 male, 2 female, 9 not applicable",
            "type": "integer",
            "enum": [0, 1, 2, 9]
        },
        "issuingAuthority": {
            "title": "",
            "description": "",
            "type": "string"
        },
        "issuingCountry": {
            "title": "",
            "description": "",
            "$ref": "#/$defs/country_code"
        },
        "documentNumber": {
            "title": "",
            "description": "",
            "type": "string"
        },
        "issuingJurisdiction": {
            "title": "",
            "description": "",
            "type": "string"
        },
        "trustAnchor": {
            "title": "",
            "description": "",
            "type": "string",
            "format": "uri"
        }
    },
    "required": [
        "vct"
    ]
}