{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mobile Driving Licence (mDL) - v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "family_name",
    "given_name",
    "birth_date",
    "issue_date",
    "expiry_date",
    "issuing_country",
    "issuing_authority",
    "document_number",
    "portrait",
    "driving_privileges",
    "un_distinguishing_sign"
  ],
  "patternProperties": {
    "^age_over_\\d+$": {
      "type": "boolean",
      "description": "Dynamic age-over flags, e.g., age_over_18, age_over_21."
    },
    "^biometric_template_[A-Za-z0-9]{2}$": {
      "type": "string",
      "contentEncoding": "base64"
    }
  },
  "properties": {
    "family_name": {
      "type": "string",
      "maxLength": 150,
      "description": "Last name, using Latin-1 characters"
    },
    "given_name": {
      "type": "string",
      "maxLength": 150,
      "description": "First names, using Latin-1 characters"
    },
    "birth_date": {
      "type": "string",
      "format": "date"
    },
    "issue_date": {
      "type": "string",
      "format": "date"
    },
    "expiry_date": {
      "type": "string",
      "format": "date"
    },
    "issuing_country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "Alpha-2 ISO 3166-1 country code"
    },
    "issuing_authority": {
      "type": "string",
      "maxLength": 150,
      "description": "Name of the issuing authority"
    },
    "document_number": {
      "type": "string",
      "maxLength": 150
    },
    "portrait": {
      "type": "string",
      "contentEncoding": "base64",
      "description": "Base64-encoded image"
    },
    "driving_privileges": {
      "$ref": "#/$defs/driving_privileges"
    },
    "un_distinguishing_sign": {
      "type": "string"
    },
    "administrative_number": {
      "type": "string",
      "maxLength": 150
    },
    "sex": {
      "type": "integer",
      "description": "As defined in ISO/IEC 5218"
    },
    "height": {
      "type": "integer"
    },
    "weight": {
      "type": "integer"
    },
    "eye_colour": {
      "type": "string",
      "enum": [
        "black",
        "blue",
        "brown",
        "dichromatic",
        "grey",
        "green",
        "hazel",
        "maroon",
        "pink",
        "unknown"
      ]
    },
    "hair_colour": {
      "type": "string",
      "enum": [
        "bald",
        "black",
        "blond",
        "brown",
        "grey",
        "red",
        "auburn",
        "sandy",
        "white",
        "unknown"
      ]
    },
    "birth_place": {
      "type": "string",
      "maxLength": 150
    },
    "resident_address": {
      "type": "string",
      "maxLength": 150
    },
    "portrait_capture_date": {
      "type": "string",
      "format": "date"
    },
    "age_in_years": {
      "type": "integer"
    },
    "age_birth_year": {
      "type": "integer"
    },
    "issuing_jurisdiction": {
      "type": "string"
    },
    "nationality": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "resident_city": {
      "type": "string",
      "maxLength": 150
    },
    "resident_state": {
      "type": "string",
      "maxLength": 150
    },
    "resident_postal_code": {
      "type": "string",
      "maxLength": 150
    },
    "resident_country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "family_name_national_character": {
      "type": "string"
    },
    "given_name_national_character": {
      "type": "string"
    },
    "signature_usual_mark": {
      "type": "string",
      "contentEncoding": "base64"
    }
  },
  "$defs": {
    "driving_privileges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/driving_privilege"
      }
    },
    "driving_privilege": {
      "description": "List of driving privileges for the mDL holder. Can be empty. Each privilege indicates a vehicle category and any restrictions or conditions, as defined in ISO/IEC 18013-1:2018 Clause 5 and Annex B, and ISO/IEC 18013-2:2020 Annex A.",
      "type": "object",
      "required": ["vehicle_category_code"],
      "properties": {
        "vehicle_category_code": {
          "type": "string",
          "description": "Vehicle category code as defined in ISO/IEC 18013-1:2018 Annex B."
        },
        "issue_date": {
          "type": "string",
          "format": "date",
          "description": "Date when the driving privilege was issued (optional)."
        },
        "expiry_date": {
          "type": "string",
          "format": "date",
          "description": "Date when the driving privilege expires (optional)."
        },
        "codes": {
          "type": "array",
          "description": "Array of restriction or condition codes. Defined in ISO/IEC 18013-2:2020 Annex A.",
          "items": {
            "type": "object",
            "required": ["code"],
            "properties": {
              "code": {
                "type": "string",
                "description": "Code representing a restriction or condition."
              },
              "sign": {
                "type": "string",
                "description": "Sign associated with the code, per ISO/IEC 18013-2 Annex A (optional)."
              },
              "value": {
                "type": "string",
                "description": "Value associated with the code, per ISO/IEC 18013-2 Annex A (optional)."
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}